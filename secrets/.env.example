# libanaf environment configuration
# Copy this file to secrets/.env (or the path pointed to by LIBANAF_ENV_FILE)
# and fill in real values.  Never commit the real .env file.
#
# Env var format: LIBANAF_<SECTION>__<KEY>=value
# All settings are optional except those marked REQUIRED.

# ---------------------------------------------------------------------------
# Auth — OAuth2 application credentials (REQUIRED)
# Register your app at https://logincert.anaf.ro/anaf-oauth2/
# ---------------------------------------------------------------------------
LIBANAF_AUTH__CLIENT_ID=your_client_id_here
LIBANAF_AUTH__CLIENT_SECRET=your_client_secret_here
LIBANAF_AUTH__REDIRECT_URI=https://localhost:8000/callback

# Authorization / token endpoint overrides (defaults shown, usually no need to change)
# LIBANAF_AUTH__AUTH_URL=https://logincert.anaf.ro/anaf-oauth2/v1/authorize
# LIBANAF_AUTH__TOKEN_URL=https://logincert.anaf.ro/anaf-oauth2/v1/token
# LIBANAF_AUTH__REVOKE_URL=https://logincert.anaf.ro/anaf-oauth2/v1/revoke

# ---------------------------------------------------------------------------
# Connection — runtime tokens (written automatically by `libanaf auth`)
# ---------------------------------------------------------------------------
LIBANAF_CONNECTION__ACCESS_TOKEN=
LIBANAF_CONNECTION__REFRESH_TOKEN=

# TLS cert/key for the local OAuth callback server (required when using HTTPS redirect URI)
LIBANAF_CONNECTION__TLS_CERT_FILE=/path/to/localhost.crt
LIBANAF_CONNECTION__TLS_KEY_FILE=/path/to/localhost.key

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# LIBANAF_STORAGE__DOWNLOAD_DIR=dlds/
# LIBANAF_STORAGE__DEFAULT_CIF=19507820

# ---------------------------------------------------------------------------
# Retry policy
# ---------------------------------------------------------------------------
# LIBANAF_RETRY__COUNT=3
# LIBANAF_RETRY__DELAY=5
# LIBANAF_RETRY__BACKOFF_FACTOR=2
# LIBANAF_RETRY__MAX_DELAY=20

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# LIBANAF_LOG__CONFIG=/path/to/conf/logging_py.json
# LIBANAF_LOG__FILE=/path/to/logs/libanaf.log

# ---------------------------------------------------------------------------
# Notifications — email alerts on sync failures
#
# Leave LIBANAF_NOTIFICATION__EMAIL_TO unset (or empty) to disable all alerts.
#
# Gmail setup:
#   SMTP_HOST = smtp.gmail.com
#   SMTP_PORT = 587
#   SMTP_USER = your Gmail address
#   SMTP_PASSWORD = a Gmail App Password (NOT your account password)
#     → Google Account › Security › 2-Step Verification › App passwords
# ---------------------------------------------------------------------------
LIBANAF_NOTIFICATION__EMAIL_TO=ctrifu@gmail.com
LIBANAF_NOTIFICATION__SMTP_HOST=smtp.gmail.com
LIBANAF_NOTIFICATION__SMTP_PORT=587
LIBANAF_NOTIFICATION__SMTP_USER=ctrifu@gmail.com
LIBANAF_NOTIFICATION__SMTP_PASSWORD=your_gmail_app_password_here

# How many consecutive network/API failures before the first alert is sent (default: 5)
# LIBANAF_NOTIFICATION__NETWORK_FAILURE_THRESHOLD=5

# ---------------------------------------------------------------------------
# State — path to the persistent failure-counter JSON file
# ---------------------------------------------------------------------------
# LIBANAF_STATE__STATE_FILE=state/sync_state.json
